    <bpmn:sequenceFlow id="F_MA10" sourceRef="Gw_Anpassen" targetRef="End_MA_Abgelehnt" name="Nein"/>
  </bpmn:process>
  <bpmn:process id="Process_Vorgesetzter" name="Vorgesetzte/r" isExecutable="true">
    <bpmn:startEvent id="Start_VG" name="Urlaubsantrag erhalten">
      <bpmn:messageEventDefinition id="EventDef_5"/>
      <bpmn:outgoing>F_VG1</bpmn:outgoing>
    </bpmn:startEvent>
