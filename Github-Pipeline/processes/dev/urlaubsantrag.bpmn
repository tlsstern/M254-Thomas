      <bpmn:incoming>F_HR3</bpmn:incoming>
      <bpmn:outgoing>F_HR6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_HR" name="HR-Vorgang abgeschlossen">
      <bpmn:incoming>F_HR5</bpmn:incoming>
      <bpmn:incoming>F_HR6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_HR1" sourceRef="Start_HR" targetRef="Gw_HR_Entscheid" name=""/>
    <bpmn:sequenceFlow id="F_HR2" sourceRef="Gw_HR_Entscheid" targetRef="Task_DB_Eintrag" name="Ja"/>
    <bpmn:sequenceFlow id="F_HR3" sourceRef="Gw_HR_Entscheid" targetRef="Task_Ablehnung_Loggen" name="Nein"/>
