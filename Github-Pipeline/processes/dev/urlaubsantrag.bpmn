      <bpmn:outgoing>F_VG6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_EntscheidSenden" name="Entscheid an Mitarbeiter senden">
      <bpmn:incoming>F_VG5</bpmn:incoming>
      <bpmn:incoming>F_VG6</bpmn:incoming>
      <bpmn:outgoing>F_VG7</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Task_HR_Benachrichtigen" name="HR-System benachrichtigen">
      <bpmn:incoming>F_VG7</bpmn:incoming>
      <bpmn:outgoing>F_VG8</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_VG" name="Bearbeitung abgeschlossen">
      <bpmn:incoming>F_VG8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_VG1" sourceRef="Start_VG" targetRef="Task_AntragPruefen" name=""/>
    <bpmn:sequenceFlow id="F_VG2" sourceRef="Task_AntragPruefen" targetRef="Gw_Genehmigung" name=""/>
