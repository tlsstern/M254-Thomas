    <bpmn:sequenceFlow id="F_VG8" sourceRef="Task_HR_Benachrichtigen" targetRef="End_VG" name=""/>
  </bpmn:process>
  <bpmn:process id="Process_HR" name="HR-System" isExecutable="true">
    <bpmn:startEvent id="Start_HR" name="Benachrichtigung erhalten">
      <bpmn:messageEventDefinition id="EventDef_6"/>
      <bpmn:outgoing>F_HR1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gw_HR_Entscheid" name="Genehmigt?">
