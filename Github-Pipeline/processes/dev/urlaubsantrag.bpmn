    <bpmn:sequenceFlow id="F_MA6" sourceRef="Gw_Entscheid_MA" targetRef="Task_AntragAnpassen" name="Nein"/>
    <bpmn:sequenceFlow id="F_MA7" sourceRef="Task_UrlaubPlanen" targetRef="End_MA_Genehmigt" name=""/>
    <bpmn:sequenceFlow id="F_MA8" sourceRef="Task_AntragAnpassen" targetRef="Gw_Anpassen" name=""/>
