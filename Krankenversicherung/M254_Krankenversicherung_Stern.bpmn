    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_InformierenAblehnung" targetRef="EndEvent_Ablehnung" name=""/>
    <bpmn:sequenceFlow id="Flow_Teilweise" sourceRef="Gateway_Erstattung" targetRef="Task_InformierenTeilweise" name="Teilweise"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_InformierenTeilweise" targetRef="Gateway_Reaction" name=""/>
