    <bpmn:sequenceFlow id="Flow_6" sourceRef="Event_10Tage" targetRef="EndEvent_Terminiert" name=""/>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Event_PositiveReaktion" targetRef="Task_Erstatten" name=""/>
    <bpmn:sequenceFlow id="Flow_Komplett" sourceRef="Gateway_Erstattung" targetRef="Task_Erstatten" name="Komplett/Ganz"/>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Erstatten" targetRef="Task_InformierenErstattung" name=""/>
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_InformierenErstattung" targetRef="EndEvent_Erstattet" name=""/>
  </bpmn:process>
