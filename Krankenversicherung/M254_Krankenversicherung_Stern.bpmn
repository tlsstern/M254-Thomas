<?xml version="1.0" ?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="python-bpmn-maker" exporterVersion="4.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Krankenversicherung_Process" name="Krankenversicherung (#66)" processRef="Krankenversicherung_Process"/>
  </bpmn:collaboration>
  <bpmn:process id="Krankenversicherung_Process" name="Krankenversicherung (#66)" isExecutable="true">
    <bpmn:laneSet id="LaneSet_Krankenversicherung_Process">
      <bpmn:lane id="Lane_Sachbearbeitung" name="Krankenversicherung">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Pruefen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Vollstaendig</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Anfordern</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_BelegeErhalten</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Ablegen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Zusammenstellen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ErstattungPruefen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Erstattung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InformierenAblehnung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Ablehnung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InformierenTeilweise</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Reaction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_10Tage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Terminiert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_PositiveReaktion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Erstatten</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InformierenErstattung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Erstattet</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Abrechnung eingetroffen">
      <bpmn:messageEventDefinition id="EventDef_1"/>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Pruefen" name="Vollständigkeit der Belege prüfen">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_Loop</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Vollstaendig" name="Belege vollständig?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Nein</bpmn:outgoing>
      <bpmn:outgoing>Flow_Ja</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="Gateway_Split" name="Unvollständig">
      <bpmn:incoming>Flow_Nein</bpmn:incoming>
      <bpmn:outgoing>Flow_Split1</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split2</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sendTask id="Task_Anfordern" name="Fehlende Belege anfordern">
      <bpmn:incoming>Flow_Split1</bpmn:incoming>
      <bpmn:outgoing>Flow_Split1a</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Event_BelegeErhalten" name="Belege erhalten">
      <bpmn:messageEventDefinition id="EventDef_2"/>
      <bpmn:incoming>Flow_Split1a</bpmn:incoming>
      <bpmn:outgoing>Flow_Split1b</bpmn:outgoing>
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Ablegen" name="Erhaltene Belege ablegen">
      <bpmn:incoming>Flow_Split2</bpmn:incoming>
      <bpmn:outgoing>Flow_Split2a</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_Join" name="">
      <bpmn:incoming>Flow_Split1b</bpmn:incoming>
      <bpmn:incoming>Flow_Split2a</bpmn:incoming>
      <bpmn:outgoing>Flow_Join</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_Zusammenstellen" name="Belege zusammenstellen">
      <bpmn:incoming>Flow_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Loop</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ErstattungPruefen" name="Erstattungsbetrag prüfen">
      <bpmn:incoming>Flow_Ja</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Erstattung" name="Erstattung?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_GarNicht</bpmn:outgoing>
      <bpmn:outgoing>Flow_Teilweise</bpmn:outgoing>
      <bpmn:outgoing>Flow_Komplett</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_InformierenAblehnung" name="Kunden informieren (Ablehnung)">
      <bpmn:incoming>Flow_GarNicht</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndEvent_Ablehnung" name="Prozess beendet">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_InformierenTeilweise" name="Kunden informieren (Teilweise)">
      <bpmn:incoming>Flow_Teilweise</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:eventBasedGateway id="Gateway_Reaction" name="Reaktion?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_EBG_1</bpmn:outgoing>
      <bpmn:outgoing>Flow_EBG_2</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_10Tage" name="10 Tage vergangen">
      <bpmn:timerEventDefinition id="EventDef_3">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P10D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
      <bpmn:incoming>Flow_EBG_1</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Terminiert" name="Prozess terminiert">
      <bpmn:terminateEventDefinition id="EventDef_4"/>
      <bpmn:incoming>Flow_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="Event_PositiveReaktion" name="Positive Reaktion">
      <bpmn:messageEventDefinition id="EventDef_5"/>
      <bpmn:incoming>Flow_EBG_2</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Erstatten" name="Erstattung durchführen">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:incoming>Flow_Komplett</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_InformierenErstattung" name="Kunden über Erstattung informieren">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndEvent_Erstattet" name="Prozess beendet">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_Pruefen" name=""/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Pruefen" targetRef="Gateway_Vollstaendig" name=""/>
    <bpmn:sequenceFlow id="Flow_Nein" sourceRef="Gateway_Vollstaendig" targetRef="Gateway_Split" name="Nein"/>
    <bpmn:sequenceFlow id="Flow_Split1" sourceRef="Gateway_Split" targetRef="Task_Anfordern" name=""/>
    <bpmn:sequenceFlow id="Flow_Split1a" sourceRef="Task_Anfordern" targetRef="Event_BelegeErhalten" name=""/>
    <bpmn:sequenceFlow id="Flow_Split1b" sourceRef="Event_BelegeErhalten" targetRef="Gateway_Join" name=""/>
    <bpmn:sequenceFlow id="Flow_Split2" sourceRef="Gateway_Split" targetRef="Task_Ablegen" name=""/>
    <bpmn:sequenceFlow id="Flow_Split2a" sourceRef="Task_Ablegen" targetRef="Gateway_Join" name=""/>
