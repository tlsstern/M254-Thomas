      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gw_RentFinal" name="Vermieten?">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_NoRentFinal" name="Abgeschlossen (Keine Vermietung)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_SendContract" name="Mietvertrag senden">
