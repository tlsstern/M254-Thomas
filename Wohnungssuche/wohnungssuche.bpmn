      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepRequest_di" bpmnElement="Task_PrepRequest">
        <dc:Bounds x="740" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendRequest_di" bpmnElement="Task_SendRequest">
        <dc:Bounds x="890" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_EventBased_di" bpmnElement="Gw_EventBased">
        <dc:Bounds x="1040" y="195" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1030" y="250" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_Rejection_di" bpmnElement="Catch_Rejection">
        <dc:Bounds x="1140" y="112" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1130" y="153" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Rejection_di" bpmnElement="End_Rejection">
        <dc:Bounds x="1240" y="112" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1230" y="153" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_Invite_di" bpmnElement="Catch_Invite">
        <dc:Bounds x="1140" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1130" y="243" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Visit_di" bpmnElement="Task_Visit">
        <dc:Bounds x="1240" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_Rent_di" bpmnElement="Gw_Rent">
        <dc:Bounds x="1380" y="195" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1370" y="250" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_NoRent_di" bpmnElement="End_NoRent">
        <dc:Bounds x="1480" y="112" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1470" y="153" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_InformInterest_di" bpmnElement="Task_InformInterest">
        <dc:Bounds x="1480" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_Contract_di" bpmnElement="Catch_Contract">
        <dc:Bounds x="1640" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1630" y="243" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SignContract_di" bpmnElement="Task_SignContract">
        <dc:Bounds x="1740" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendContractBack_di" bpmnElement="Task_SendContractBack">
        <dc:Bounds x="1890" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_TenantSuccess_di" bpmnElement="End_TenantSuccess">
        <dc:Bounds x="2040" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2030" y="243" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_Vermieter_di" bpmnElement="Start_Vermieter">
        <dc:Bounds x="890" y="602" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="880" y="643" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_Interesting_di" bpmnElement="Gw_Interesting">
        <dc:Bounds x="980" y="595" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="970" y="650" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendRejection_di" bpmnElement="Task_SendRejection">
        <dc:Bounds x="1108" y="480" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_V_Rejection_di" bpmnElement="End_V_Rejection">
        <dc:Bounds x="1240" y="502" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1230" y="543" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendInvite_di" bpmnElement="Task_SendInvite">
        <dc:Bounds x="1108" y="580" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_Interest_di" bpmnElement="Catch_Interest">
        <dc:Bounds x="1480" y="602" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1470" y="643" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FinalDecision_di" bpmnElement="Task_FinalDecision">
        <dc:Bounds x="1580" y="580" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_RentFinal_di" bpmnElement="Gw_RentFinal">
        <dc:Bounds x="1740" y="595" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1730" y="650" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_NoRentFinal_di" bpmnElement="End_NoRentFinal">
        <dc:Bounds x="1840" y="502" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1830" y="543" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendContract_di" bpmnElement="Task_SendContract">
        <dc:Bounds x="1840" y="580" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_ContractBack_di" bpmnElement="Catch_ContractBack">
        <dc:Bounds x="1990" y="602" width="36" height="36"/>
        <bpmndi:BPMNLabel>
