    </bpmn:sendTask>
    <bpmn:task id="Task_SignContract" name="Vertrag unterschreiben">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_SendContractBack" name="Vertrag zurücksenden">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Task_ReceiveContract" name="Vertrag erhalten">
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:endEvent id="End_VermieterSuccess" name="Wohnung vermietet">
      <bpmn:incoming>Flow_24</bpmn:incoming>
