<?xml version="1.0" ?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="python-bpmn-maker" exporterVersion="1.0">
  <bpmn:process id="Steuerkanzlei_Process" name="Steuererklärung erstellen" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Mandant" name="Unterlagen eingereicht">
      <bpmn:outgoing>Flow_Start_Zusammenstellen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_UnterlagenZusammenstellen" name="Unterlagen zusammenstellen">
      <bpmn:incoming>Flow_Start_Zusammenstellen</bpmn:incoming>
      <bpmn:outgoing>Flow_Zusammenstellen_Pruefen</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_UnterlagenPruefen" name="Unterlagen auf Vollständigkeit prüfen">
      <bpmn:incoming>Flow_Zusammenstellen_Pruefen</bpmn:incoming>
      <bpmn:outgoing>Flow_Pruefen_GatewayVollstaendig</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_UnterlagenVollstaendig" name="Vollständig?">
      <bpmn:incoming>Flow_Pruefen_GatewayVollstaendig</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayVollstaendig_Nein</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayVollstaendig_Ja</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_MandantKontaktieren" name="Mandant bzgl. fehlender Unterlagen kontaktieren">
      <bpmn:incoming>Flow_GatewayVollstaendig_Nein</bpmn:incoming>
      <bpmn:outgoing>Flow_Kontaktieren_Bereitstellen</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:task id="Task_FehlendeUnterlagenBereitstellen" name="Fehlende Unterlagen bereitstellen">
      <bpmn:incoming>Flow_Kontaktieren_Bereitstellen</bpmn:incoming>
      <bpmn:outgoing>Flow_Bereitstellen_Weiterleiten_Fehlend</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_FallWeiterleiten" name="Fall an Steuergehilfen weiterleiten">
      <bpmn:incoming>Flow_Bereitstellen_Weiterleiten_Fehlend</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayVollstaendig_Ja</bpmn:incoming>
      <bpmn:outgoing>Flow_Weiterleiten_Einarbeiten</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_UnterlagenEinarbeiten" name="In Unterlagen einarbeiten">
      <bpmn:incoming>Flow_Weiterleiten_Einarbeiten</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayEinarbeitungBeendet_Nein</bpmn:incoming>
      <bpmn:outgoing>Flow_Einarbeiten_GatewayRueckfragen</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Rueckfragen" name="Rückfragen?">
      <bpmn:incoming>Flow_Einarbeiten_GatewayRueckfragen</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRueckfragen_Ja</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRueckfragen_Nein</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_RueckfragenKlaeren" name="Rückfragen klären">
      <bpmn:incoming>Flow_GatewayRueckfragen_Ja</bpmn:incoming>
      <bpmn:outgoing>Flow_RueckfragenKlaeren_GatewayEinarbeitungBeendet</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_EinarbeitungBeendet" name="Einarbeitung beendet?">
      <bpmn:incoming>Flow_RueckfragenKlaeren_GatewayEinarbeitungBeendet</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayEinarbeitungBeendet_Nein</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayEinarbeitungBeendet_Ja</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_SteuererklaerungBearbeiten" name="Steuererklärung bearbeiten">
      <bpmn:incoming>Flow_GatewayRueckfragen_Nein</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayEinarbeitungBeendet_Ja</bpmn:incoming>
      <bpmn:outgoing>Flow_Bearbeiten_Uebermitteln</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_ErklaerungUebermitteln" name="Erklärung an Finanzamt übermitteln">
      <bpmn:incoming>Flow_Bearbeiten_Uebermitteln</bpmn:incoming>
      <bpmn:outgoing>Flow_Uebermitteln_FinanzamtBearbeiten</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:task id="Task_SteuerbescheidBearbeiten" name="Steuerbescheid bearbeiten">
      <bpmn:incoming>Flow_Uebermitteln_FinanzamtBearbeiten</bpmn:incoming>
      <bpmn:outgoing>Flow_FinanzamtBearbeiten_BescheidErhalten</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Event_SteuerbescheidErhalten" name="Steuerbescheid erhalten">
      <bpmn:incoming>Flow_FinanzamtBearbeiten_BescheidErhalten</bpmn:incoming>
      <bpmn:outgoing>Flow_BescheidErhalten_BescheidPruefen</bpmn:outgoing>
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_SteuerbescheidPruefen" name="Steuerbescheid prüfen">
      <bpmn:incoming>Flow_BescheidErhalten_BescheidPruefen</bpmn:incoming>
      <bpmn:outgoing>Flow_BescheidPruefen_GatewayParallel</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_Parallel_SendenArchivieren" name="Senden und Archivieren">
      <bpmn:incoming>Flow_BescheidPruefen_GatewayParallel</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayParallel_Senden</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayParallel_Archivieren</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sendTask id="Task_BescheidAnMandantSenden" name="Bescheid an Mandanten senden">
      <bpmn:incoming>Flow_GatewayParallel_Senden</bpmn:incoming>
      <bpmn:outgoing>Flow_Senden_Ablegen</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:task id="Task_BescheidInOrdnerAblegen" name="Bescheid in Ordner ablegen">
      <bpmn:incoming>Flow_Senden_Ablegen</bpmn:incoming>
      <bpmn:outgoing>Flow_Ablegen_GatewayParallelEnde</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_BescheidArchivieren" name="Kopie im Archiv ablegen">
      <bpmn:incoming>Flow_GatewayParallel_Archivieren</bpmn:incoming>
      <bpmn:outgoing>Flow_Archivieren_GatewayParallelEnde</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_Parallel_SendenArchivierenEnde" name="Ende Senden und Archivieren">
      <bpmn:incoming>Flow_Ablegen_GatewayParallelEnde</bpmn:incoming>
      <bpmn:incoming>Flow_Archivieren_GatewayParallelEnde</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayParallelEnde_EndEvent</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:endEvent id="EndEvent_ProzessBeendet" name="Prozess beendet">
      <bpmn:incoming>Flow_GatewayParallelEnde_EndEvent</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Zusammenstellen" sourceRef="StartEvent_Mandant" targetRef="Task_UnterlagenZusammenstellen" name=""/>
    <bpmn:sequenceFlow id="Flow_Zusammenstellen_Pruefen" sourceRef="Task_UnterlagenZusammenstellen" targetRef="Task_UnterlagenPruefen" name=""/>
    <bpmn:sequenceFlow id="Flow_Pruefen_GatewayVollstaendig" sourceRef="Task_UnterlagenPruefen" targetRef="Gateway_UnterlagenVollstaendig" name=""/>
    <bpmn:sequenceFlow id="Flow_GatewayVollstaendig_Nein" sourceRef="Gateway_UnterlagenVollstaendig" targetRef="Task_MandantKontaktieren" name="Nein"/>
    <bpmn:sequenceFlow id="Flow_Kontaktieren_Bereitstellen" sourceRef="Task_MandantKontaktieren" targetRef="Task_FehlendeUnterlagenBereitstellen" name=""/>
    <bpmn:sequenceFlow id="Flow_Bereitstellen_Weiterleiten_Fehlend" sourceRef="Task_FehlendeUnterlagenBereitstellen" targetRef="Task_FallWeiterleiten" name=""/>
    <bpmn:sequenceFlow id="Flow_GatewayVollstaendig_Ja" sourceRef="Gateway_UnterlagenVollstaendig" targetRef="Task_FallWeiterleiten" name="Ja"/>
    <bpmn:sequenceFlow id="Flow_Weiterleiten_Einarbeiten" sourceRef="Task_FallWeiterleiten" targetRef="Task_UnterlagenEinarbeiten" name=""/>
    <bpmn:sequenceFlow id="Flow_Einarbeiten_GatewayRueckfragen" sourceRef="Task_UnterlagenEinarbeiten" targetRef="Gateway_Rueckfragen" name=""/>
    <bpmn:sequenceFlow id="Flow_GatewayRueckfragen_Ja" sourceRef="Gateway_Rueckfragen" targetRef="Task_RueckfragenKlaeren" name="Ja"/>
    <bpmn:sequenceFlow id="Flow_GatewayRueckfragen_Nein" sourceRef="Gateway_Rueckfragen" targetRef="Task_SteuererklaerungBearbeiten" name="Nein"/>
    <bpmn:sequenceFlow id="Flow_RueckfragenKlaeren_GatewayEinarbeitungBeendet" sourceRef="Task_RueckfragenKlaeren" targetRef="Gateway_EinarbeitungBeendet" name=""/>
    <bpmn:sequenceFlow id="Flow_GatewayEinarbeitungBeendet_Nein" sourceRef="Gateway_EinarbeitungBeendet" targetRef="Task_UnterlagenEinarbeiten" name="Nein"/>
    <bpmn:sequenceFlow id="Flow_GatewayEinarbeitungBeendet_Ja" sourceRef="Gateway_EinarbeitungBeendet" targetRef="Task_SteuererklaerungBearbeiten" name="Ja"/>
    <bpmn:sequenceFlow id="Flow_Bearbeiten_Uebermitteln" sourceRef="Task_SteuererklaerungBearbeiten" targetRef="Task_ErklaerungUebermitteln" name=""/>
    <bpmn:sequenceFlow id="Flow_Uebermitteln_FinanzamtBearbeiten" sourceRef="Task_ErklaerungUebermitteln" targetRef="Task_SteuerbescheidBearbeiten" name="Finanzamt"/>
    <bpmn:sequenceFlow id="Flow_FinanzamtBearbeiten_BescheidErhalten" sourceRef="Task_SteuerbescheidBearbeiten" targetRef="Event_SteuerbescheidErhalten" name=""/>
    <bpmn:sequenceFlow id="Flow_BescheidErhalten_BescheidPruefen" sourceRef="Event_SteuerbescheidErhalten" targetRef="Task_SteuerbescheidPruefen" name=""/>
    <bpmn:sequenceFlow id="Flow_BescheidPruefen_GatewayParallel" sourceRef="Task_SteuerbescheidPruefen" targetRef="Gateway_Parallel_SendenArchivieren" name=""/>
    <bpmn:sequenceFlow id="Flow_GatewayParallel_Senden" sourceRef="Gateway_Parallel_SendenArchivieren" targetRef="Task_BescheidAnMandantSenden" name=""/>
    <bpmn:sequenceFlow id="Flow_Senden_Ablegen" sourceRef="Task_BescheidAnMandantSenden" targetRef="Task_BescheidInOrdnerAblegen" name=""/>
    <bpmn:sequenceFlow id="Flow_Ablegen_GatewayParallelEnde" sourceRef="Task_BescheidInOrdnerAblegen" targetRef="Gateway_Parallel_SendenArchivierenEnde" name=""/>
    <bpmn:sequenceFlow id="Flow_GatewayParallel_Archivieren" sourceRef="Gateway_Parallel_SendenArchivieren" targetRef="Task_BescheidArchivieren" name=""/>
    <bpmn:sequenceFlow id="Flow_Archivieren_GatewayParallelEnde" sourceRef="Task_BescheidArchivieren" targetRef="Gateway_Parallel_SendenArchivierenEnde" name=""/>
    <bpmn:sequenceFlow id="Flow_GatewayParallelEnde_EndEvent" sourceRef="Gateway_Parallel_SendenArchivierenEnde" targetRef="EndEvent_ProzessBeendet" name=""/>
  </bpmn:process>
